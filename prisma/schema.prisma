generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum ScriptType {
  GOOGLE_ANALYTICS
  GOOGLE_ADS
  GOOGLE_TAG_MANAGER
  META_PIXEL
  CUSTOM
}

enum ScriptPosition {
  HEAD
  BODY_START
  BODY_END
}

enum ScriptSite {
  SHR
  MALETTI
  BOTH
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String?
  name                String?
  role                Role     @default(ADMIN)
  isActive            Boolean  @default(true)
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Product {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  shortDescription String?
  description      String?
  features         String[]          @default([])
  image            String?
  gallery          String[]          @default([])
  catalog          String?
  warranty         String?
  video            String?
  featured         Boolean           @default(false)
  active           Boolean           @default(true)
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  ogImage          String?
  categoryId       String?
  category         Category?         @relation("ProductPrimaryCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  categories       ProductCategory[]
  brands           ProductBrand[]
  specifications   Specification[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Brand {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  logo        String?
  highlights  String[]       @default([])
  image       String?
  active      Boolean        @default(true)
  products    ProductBrand[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Category {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  description       String?
  image             String?
  active            Boolean           @default(true)
  order             Int               @default(0)
  parentId          String?
  parent            Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]        @relation("CategoryHierarchy")
  products          Product[]         @relation("ProductPrimaryCategory")
  productCategories ProductCategory[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([productId, categoryId])
}

model ProductBrand {
  id        String   @id @default(cuid())
  productId String
  brandId   String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, brandId])
}

model Specification {
  id        String   @id @default(cuid())
  productId String
  label     String
  value     String
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  website     String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Catalog {
  id          String   @id @default(cuid())
  name        String
  description String?
  file        String
  thumbnail   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Banner {
  id             String   @id @default(cuid())
  badge          String?
  subtitle       String?
  title          String
  description    String?
  image          String?
  video          String?
  button1Text    String?
  button1Link    String?
  button1Color   String?  @default("white")
  button1Rounded Boolean  @default(false)
  button2Text    String?
  button2Link    String?
  button2Color   String?  @default("outline")
  button2Rounded Boolean  @default(false)
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BlogPost {
  id              String             @id @default(cuid())
  title           String
  slug            String
  excerpt         String?
  content         String
  image           String?
  cover           String?
  published       Boolean            @default(false)
  publishedAt     DateTime?
  views           Int                @default(0)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  categories      BlogPostCategory[]
  tags            BlogPostTag[]
  comments        BlogComment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([slug, published])
}

model BlogCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  color       String?            @default("#000000")
  posts       BlogPostCategory[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model BlogTag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  posts     BlogPostTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model BlogPostCategory {
  id         String       @id @default(cuid())
  postId     String
  categoryId String
  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([postId, categoryId])
}

model BlogPostTag {
  id        String    @id @default(cuid())
  postId    String
  tagId     String
  post      BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       BlogTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, tagId])
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  name      String
  email     String
  content   String
  approved  Boolean  @default(false)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  title           String?
  description     String?
  published       Boolean     @default(false)
  isSystem        Boolean     @default(false)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  blocks          PageBlock[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model PageBlock {
  id        String   @id @default(cuid())
  pageId    String
  type      String
  content   Json
  order     Int      @default(0)
  active    Boolean  @default(true)
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId, order])
}

model HomeSection {
  id          String   @id @default(cuid())
  sectionId   String   @unique
  title       String?
  subtitle    String?
  description String?
  content     Json?
  image       String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String?
  siteDescription String?
  logo            String?
  logoDark        String?
  favicon         String?
  phone           String?
  whatsapp        String?
  email           String?
  address         String?
  cnpj            String?
  openingHours    String?
  instagram       String?
  facebook        String?
  linkedin        String?
  youtube         String?
  seoConfig       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LayoutConfig {
  id        String   @id @default(cuid())
  type      String
  variant   String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, variant], name: "type_variant")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  country   String?
  userAgent String?
  referrer  String?
  ip        String?
  createdAt DateTime @default(now())
}

model Click {
  id        String   @id @default(cuid())
  label     String?
  href      String?
  page      String?
  createdAt DateTime @default(now())
}

model Script {
  id        String         @id @default(cuid())
  name      String
  type      ScriptType     @default(CUSTOM)
  position  ScriptPosition @default(HEAD)
  code      String
  active    Boolean        @default(true)
  site      ScriptSite     @default(BOTH)
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model KommoSettings {
  id           String   @id @default(cuid())
  enabled      Boolean  @default(false)
  subdomain    String?
  clientId     String?
  clientSecret String?
  redirectUri  String?
  accessToken  String?
  refreshToken String?
  tokenType    String?
  tokenExpiresAt DateTime?
  pipelineId   Int?
  pipelineName String?
  statusId     Int?
  statusName   String?
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
